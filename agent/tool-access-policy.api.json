{
  "permissions": {
    "allow": [
      "RunAzCliReadCommands",
      "RunKubectlReadCommand(kubectl get *)"
    ],
    "ask": [],
    "deny": [
      "RunInTerminal",
      "RunShellCommand",
      "RunAzCliWriteCommands",
      "RunKubectlWriteCommand",
      "bash(az * create *)",
      "bash(az * update *)",
      "bash(az * delete *)",
      "bash(az * set *)",
      "bash(az * restart *)",
      "bash(az * start *)",
      "bash(az * stop *)",
      "bash(terraform * apply *)",
      "bash(terraform * destroy *)"
    ]
  }
}
