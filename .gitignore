# --- Terraform ---
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
# Real variable files (keep only the .example)
*.tfvars
*.tfvars.json
!*.tfvars.example
# leak.auto.tfvars is the committed, non-secret GitOps source of truth for the
# planted memory-leak flag (CI applies it on merge). It contains no secrets.
!infra/leak.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl.bak

# --- Secrets / credentials (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
*.cer
azureauth.json

# --- Node ---
node_modules/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Misc ---
*.log

# --- Local clone / scratch artifacts (not part of the project) ---
/sreagent/
.newtag.txt
